<Page
    x:Class="UniversalPauseButton.Widget.MainWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16" RowSpacing="12" XYFocusKeyboardNavigation="Enabled">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button x:Name="PauseButton"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                FontSize="20"
                IsTabStop="True"
                UseSystemFocusVisuals="True"
                Click="PauseButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon x:Name="ButtonIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE769;" />
                <TextBlock x:Name="ButtonText" Text="Pause" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Opacity="0.8"
                   Text="Ready." />
    </Grid>
</Page>
